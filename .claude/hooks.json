{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|exec_command)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-unverified-commits.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-make-command.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-splat-split.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-ctx-file.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-temp-file.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-asm-processor-edits.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-ctx-file.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-temp-file.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-ctx-file.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-temp-file.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-asm-edits.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-asm-processor-edits.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-sha1-edits.sh"
          }
        ]
      },
      {
        "matcher": "^(Edit|apply_patch)$",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-ctx-file.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-temp-file.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-asm-edits.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-asm-processor-edits.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-sha1-edits.sh"
          }
        ]
      }
    ]
  }
}
